---
import Layout from '../layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Button } from "@/components/ui/button";
import { authApi } from '@/lib/api';
import { setUser } from '@/lib/auth';
---

<Layout title="Iniciar Sesión" showSidebar={false}>
  <div class="fixed inset-0 flex items-center justify-center">
    <div class="w-72">
      <Card className="border-slate-200 shadow-lg bg-white">
        <CardHeader className="text-center pb-2">
          <CardTitle className="text-base font-bold text-slate-900">Bienvenido</CardTitle>
          <CardDescription className="text-slate-500 text-xs">Ingresa tus credenciales</CardDescription>
        </CardHeader>
        <CardContent className="pt-2">
          <form id="login-form" className="space-y-3">
            <div className="space-y-1">
              <Label htmlFor="username" className="text-slate-700 text-xs font-medium">Usuario</Label>
              <Input 
                id="username" 
                type="text" 
                placeholder="Usuario" 
                required 
                className="h-8 rounded-lg border-slate-200 focus-visible:ring-[#30b7ff] text-sm"
              />
            </div>

            <div className="space-y-1">
              <Label htmlFor="password" className="text-slate-700 text-xs font-medium">Contraseña</Label>
              <Input 
                id="password" 
                type="password" 
                placeholder="••••••••" 
                required 
                className="h-8 rounded-lg border-slate-200 focus-visible:ring-[#30b7ff] text-sm"
              />
            </div>

            <p id="error-msg" className="text-xs text-red-500 hidden"></p>

            <Button 
              type="submit" 
              className="w-full h-8 rounded-lg bg-[#30b7ff] hover:bg-[#209fdf] text-white text-xs font-medium"
            >
              Ingresar
            </Button>
          </form>
        </CardContent>
      </Card>
    </div>
  </div>

  <script>
    import { authApi } from '@/lib/api';
    import { setUser } from '@/lib/auth';

    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const username = (document.getElementById('username') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      
      // Disable button and show loading
      if (submitBtn) {
        submitBtn.textContent = 'Ingresando...';
        (submitBtn as HTMLButtonElement).disabled = true;
      }
      
      try {
        const user = await authApi.login(username, password);
        setUser(user);
        window.location.href = '/';
      } catch (error: any) {
        if (errorMsg) {
          errorMsg.textContent = error.message || 'Usuario o contraseña incorrectos';
          errorMsg.classList.remove('hidden');
        }
        if (submitBtn) {
          submitBtn.textContent = 'Ingresar';
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  </script>
</Layout>