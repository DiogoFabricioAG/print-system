---
import Layout from '../layouts/Layout.astro';
import { Topbar } from '../components/dashboard/Topbar';
import { NavigationPanel } from '../components/dashboard/NavigationPanel';
import { UnpaidSalesCarousel } from '../components/dashboard/UnpaidSalesCarousel';
import { DashboardCharts } from '../components/dashboard/DashboardCharts';
import { salesApi, clientsApi, gastosApi, type Sale, type Client, type Gasto } from '../lib/api';

function mapSaleToViewModel(sale: Sale) {
  return {
    id: String(sale.id),
    client: sale.cliente_nombre,
    amount: sale.pago,
    status: sale.estado,
    date: sale.creado_el.split(" ")[0]
  }
}

function mapTopClientsData(sales: Sale[]) {
  const amountPerClient: Record<string, number> = {}

  sales.forEach(sale => {
    const name = sale.cliente_nombre || "Desconocido"
    if (!amountPerClient[name]) {
      amountPerClient[name] = 0
    }
    amountPerClient[name] += sale.pago
  })

  const LOCAL_CLIENT_NAME = "Cliente Local"
  const localClientAmount = amountPerClient[LOCAL_CLIENT_NAME] || 0

  // Filter out Local Client and get top 5
  const otherClients = Object.entries(amountPerClient)
    .filter(([name]) => name.toLowerCase() !== LOCAL_CLIENT_NAME.toLowerCase())
    .map(([name, amount]) => ({ name, amount }))
    .sort((a, b) => b.amount - a.amount)
    .slice(0, 5)

  // Format final data (reverse order for rechart to show highest at top)
  const finalData = []
  
  // Add others first (so they appear at the bottom of the bar chart)
  otherClients.reverse().forEach(client => {
    finalData.push(client)
  })

  // Add Local Client last (so it appears at the top of the bar chart)
  if (localClientAmount >= 0 || otherClients.length === 0) {
    finalData.push({ name: LOCAL_CLIENT_NAME, amount: localClientAmount })
  }

  return finalData
}

function mapBalanceData(sales: Sale[], gastos: Gasto[]) {
  const dailyData: Record<string, { income: number; expense: number }> = {}
  
  // Agrupar ventas
  sales.forEach(sale => {
    if (sale.estado === "Cancelado") return; // Ignorar cancelados
    
    const dateStr = sale.creado_el.split(" ")[0] // YYYY-MM-DD
    if (!dailyData[dateStr]) {
      dailyData[dateStr] = { income: 0, expense: 0 }
    }
    dailyData[dateStr].income += sale.pago
  })

  // Agrupar gastos
  gastos.forEach(gasto => {
    if (!gasto.creado_el) return;
    
    const dateStr = gasto.creado_el.split(" ")[0] // YYYY-MM-DD
    if (!dailyData[dateStr]) {
      dailyData[dateStr] = { income: 0, expense: 0 }
    }
    dailyData[dateStr].expense += gasto.monto
  })

  // Obtener fechas únicas ordenadas
  const uniqueDates = Object.keys(dailyData).sort()
  
  const formatter = new Intl.DateTimeFormat('es-ES', { weekday: 'short' })
  
  if (uniqueDates.length === 0) {
    const last7Days: { date: string; income: number; expense: number }[] = []
    const today = new Date()
    for (let i = 6; i >= 0; i--) {
      const date = new Date(today)
      date.setDate(date.getDate() - i)
      const weekday = formatter.format(date)
      const capitalizedWeekday = weekday.charAt(0).toUpperCase() + weekday.slice(1)
      const dd = date.getDate().toString().padStart(2, '0')
      const mm = (date.getMonth() + 1).toString().padStart(2, '0')
      const displayKey = `${capitalizedWeekday} ${dd}/${mm}`
      last7Days.push({ date: displayKey, income: 0, expense: 0 })
    }
    return last7Days
  }

  // Encontrar la fecha más reciente y generar 7 días hacia atrás
  const latestDateStr = [...uniqueDates].sort().reverse()[0]
  const [latestYear, latestMonth, latestDay] = latestDateStr.split('-').map(Number)
  const latestDate = new Date(latestYear, latestMonth - 1, latestDay)

  const result: { date: string; income: number; expense: number }[] = []
  for (let i = 6; i >= 0; i--) {
    const date = new Date(latestDate)
    date.setDate(date.getDate() - i)
    
    const yyyy = date.getFullYear()
    const mm = (date.getMonth() + 1).toString().padStart(2, '0')
    const dd = date.getDate().toString().padStart(2, '0')
    const fullDateKey = `${yyyy}-${mm}-${dd}`
    
    const weekday = formatter.format(date)
    const capitalizedWeekday = weekday.charAt(0).toUpperCase() + weekday.slice(1)
    const displayKey = `${capitalizedWeekday} ${dd}/${mm}`
    
    result.push({
      date: displayKey,
      income: dailyData[fullDateKey]?.income || 0,
      expense: dailyData[fullDateKey]?.expense || 0
    })
  }
  
  return result
}

const { unpaidSales, topClientsData, balanceData } = await (async () => {
  try {
    const [sales, clients, gastos] = await Promise.all([
      salesApi.getAll(),
      clientsApi.getAll(),
      gastosApi.getAll()
    ])

    const unpaid = sales
      .filter(s => s.estado === "Debe" || s.estado === "En Producción")
      .slice(0, 5)
      .map(mapSaleToViewModel)

    const topClients = mapTopClientsData(sales)
    const balance = mapBalanceData(sales, gastos)

    return { 
      unpaidSales: unpaid, 
      topClientsData: topClients,
      balanceData: balance
    }
  } catch (error) {
    console.error("Error fetching dashboard data:", error)
    return { 
      unpaidSales: [], 
      topClientsData: [],
      balanceData: []
    }
  }
})();
---

<Layout title="Dashboard Comercial" showSidebar={false}>
  <div class="space-y-6 md:space-y-8 max-w-7xl mx-auto py-8">
    <Topbar client:load />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">
      <div class="lg:col-span-4 xl:col-span-3 flex flex-col min-h-[220px]">
        <NavigationPanel client:load />
      </div>
      
      <div class="lg:col-span-8 xl:col-span-9 flex flex-col min-h-[220px]">
        <UnpaidSalesCarousel sales={unpaidSales} client:load />
      </div>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">
      <div class="lg:col-span-12 flex flex-col min-h-[400px]">
        <DashboardCharts 
          topClientsData={topClientsData} 
          balanceData={balanceData}
          client:load 
        />
      </div>
    </div>
  </div>
</Layout>