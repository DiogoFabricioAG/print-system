---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { Toaster } from '@/components/ui/toaster';

interface Props {
	title: string;
	showSidebar?: boolean;
}

const { title, showSidebar = true } = Astro.props;

const currentPath = Astro.url.pathname;
const showAppNav = showSidebar;
const isLoginPage = currentPath === '/login';

const navItems = [
	{ name: 'Dashboard', path: '/', short: 'Inicio' },
	{ name: 'Clientes', path: '/clientes', short: 'Clientes' },
	{ name: 'Ventas', path: '/ventas', short: 'Ventas' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sistema de ventas y clientes" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Print System</title>
		<ClientRouter />
		<script is:inline>
			function checkAuth() {
				const user = localStorage.getItem('printsystem_user');
				const isLoginPage = window.location.pathname === '/login';
				
				if (!user && !isLoginPage) {
					window.location.href = '/login';
				} else if (user && isLoginPage) {
					window.location.href = '/';
				}
			}
			
			// Check on page load
			checkAuth();
			
			// Listen for astro page loads
			document.addEventListener('astro:page-load', checkAuth);
		</script>
	</head>
	<body class="min-h-screen overflow-x-hidden bg-cloud text-ink">
		<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
			<div class="absolute -left-24 top-8 h-72 w-72 rounded-full bg-electric/25 blur-3xl"></div>
			<div class="absolute right-0 top-1/3 h-80 w-80 rounded-full bg-spark/20 blur-3xl"></div>
			<div class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-cyan-300/20 blur-3xl"></div>
		</div>

		<div class={`relative min-h-screen ${showAppNav ? 'md:grid md:grid-cols-[17.5rem_1fr]' : ''}`}>
			{showAppNav && !isLoginPage && (
				<aside class="hidden border-r border-white/40 bg-ink/95 px-4 pb-6 pt-5 text-white shadow-2xl backdrop-blur md:flex md:flex-col" transition:persist>
					<a href="/" class="group flex items-center gap-3 px-3" transition:name="brand-lockup">
						<div class="grid h-10 w-10 place-items-center rounded-xl bg-linear-to-br from-electric to-mint text-ink shadow-lg shadow-electric/25 transition-transform duration-300 group-hover:rotate-6">
							PS
						</div>
						<div>
							<p class="font-display text-lg font-semibold leading-5">Print System</p>
							<p class="text-xs text-white/60">Control comercial</p>
						</div>
					</a>

					<nav class="mt-9 space-y-2">
						{navItems.map((item) => {
							const isActive = currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path));
							return (
								<a
									href={item.path}
									class={`block rounded-xl border px-4 py-3 text-sm font-semibold transition-all duration-300 ${
										isActive
											? 'border-electric/70 bg-electric/15 text-white shadow-lg shadow-electric/20'
											: 'border-white/10 bg-white/5 text-white/75 hover:border-white/30 hover:bg-white/10 hover:text-white'
									}`}
									transition:name={item.path === '/' ? 'route-home' : `route-${item.short.toLowerCase()}`}
								>
									{item.name}
								</a>
							);
						})}
					</nav>

					<a href="/ventas/nueva" class="mt-6 rounded-xl bg-linear-to-r from-spark to-orange-400 px-4 py-3 text-center text-sm font-bold text-ink shadow-lg shadow-spark/30 transition-transform duration-300 hover:-translate-y-0.5">
						+ Nueva venta
					</a>

					<div class="mt-auto rounded-2xl border border-white/10 bg-white/5 p-4">
						<p class="text-xs uppercase tracking-[0.2em] text-white/50">Sesion</p>
						<p class="mt-2 text-sm font-semibold text-white">Admin Comercial</p>
						<button id="logout-btn" class="mt-4 inline-flex items-center text-sm font-semibold text-mint transition-colors hover:text-white cursor-pointer">Salir</button>
					</div>
				</aside>
			)}

			<main class="relative min-h-screen">
				{showAppNav && !isLoginPage && (
					<header class="sticky top-0 z-20 border-b border-slate-200/70 bg-white/70 backdrop-blur md:border-none md:bg-transparent" transition:persist>
						<div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 md:px-8 md:pt-6">
							<div>
								<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Panel comercial</p>
								<h1 class="font-display text-xl font-bold text-ink">{title}</h1>
							</div>
						</div>
					</header>
				)}

				<section class={`mx-auto w-full ${showAppNav ? 'max-w-7xl px-4 pb-24 pt-6 md:px-8 md:pb-8' : 'max-w-6xl px-4 py-8 md:py-12'}`}>
					<slot />
				</section>
			</main>
		</div>

		{showAppNav && !isLoginPage && (
			<nav class="fixed inset-x-4 bottom-4 z-30 flex items-center justify-between rounded-2xl border border-slate-200/70 bg-white/90 p-2 shadow-2xl backdrop-blur md:hidden">
				{navItems.map((item) => {
					const isActive = currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path));
					return (
						<a
							href={item.path}
							class={`rounded-xl px-4 py-2 text-xs font-bold uppercase tracking-widest transition ${isActive ? 'bg-ink text-white' : 'text-slate-500'}`}
						>
							{item.short}
						</a>
					);
				})}
			</nav>
		)}

		<Toaster client:load />
		
		<script is:inline>
			document.getElementById('logout-btn')?.addEventListener('click', () => {
				localStorage.removeItem('printsystem_user');
				window.location.href = '/login';
			});
		</script>
	</body>
</html>